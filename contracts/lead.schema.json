{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tencate.example/contracts/lead.schema.json",
  "title": "Lead",
  "description": "One artificial-turf lead. Two tiers: the flat core (what a BDM sees; maps 1:1 to a Supabase 'lead' row) plus an optional nested 'evidence' block holding the richer extraction detail.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "external_id", "source", "organization", "state", "county",
    "summary", "evidence_quote", "source_url", "discovered_at", "location_id"
  ],
  "properties": {
    "external_id": { "type": "string", "minLength": 8 },
    "source": { "type": "string", "enum": ["web-search", "meeting-minutes"] },
    "organization": { "type": "string", "minLength": 1 },
    "organization_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "state": { "type": "string", "pattern": "^[A-Z]{2}$" },
    "county": { "type": "string" },
    "summary": { "type": "string", "minLength": 1, "maxLength": 400 },
    "evidence_quote": { "type": "string" },
    "source_url": { "type": "string", "minLength": 1 },
    "discovered_at": { "type": "string", "format": "date-time" },
    "location_id": { "type": "string", "pattern": "^us-[a-z]{2}-[a-z0-9-]+$" },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "project_name": { "type": "string", "maxLength": 255 },
        "project_address": { "type": "string" },
        "projected_start_date": { "type": "string" },
        "details": { "type": "string" },
        "contact": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "first_name": { "type": "string" }, "last_name": { "type": "string" },
            "title": { "type": "string" }, "phone": { "type": "string" },
            "email": { "type": "string" }
          }
        },
        "source_ids": { "type": "array", "items": { "type": "string", "pattern": "^SRC-[0-9]{3,}$" } },
        "source_urls": { "type": "array", "items": { "type": "string" } },
        "matched_terms": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "needs_review": { "type": "boolean" },
        "run_timestamp": { "type": "string" }
      }
    }
  }
}
